#!/usr/bin/env bash
# pre-push: 允许 src/、docs/*.md；禁止 map/pgm/本地部署草稿等。

set -euo pipefail

ROOT_ALLOW_RE='^(\.gitignore|\.gitattributes|README\.md|\.githooks/|scripts/)'

is_allowed_path() {
  local f="$1"

  if [[ "$f" =~ $ROOT_ALLOW_RE ]]; then
    return 0
  fi

  if [[ "$f" =~ /map/ ]] || [[ "$f" =~ ^map/ ]]; then
    return 1
  fi
  if [[ "$f" =~ (^|/)(build|install|log|tools)(/|$) ]]; then
    return 1
  fi
  if [[ "$f" =~ \.(pgm|tar\.gz)$ ]]; then
    return 1
  fi
  if [[ "$f" == apm.params ]] || [[ "$f" == push_build_nx.sh ]] || [[ "$f" == rviz2.rviz ]]; then
    return 1
  fi

  if [[ "$f" =~ ^docs/.+\.md$ ]]; then
    return 0
  fi

  if [[ "$f" =~ ^src/ ]]; then
    if [[ "$f" =~ /map/ ]] || [[ "$f" =~ \.pgm$ ]]; then
      return 1
    fi
    return 0
  fi

  return 1
}

collect_blocked() {
  local range="$1"
  local blocked=""
  local f
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if ! is_allowed_path "$f"; then
      blocked+="${f}"$'\n'
    fi
  done < <(git -c core.quotepath=false diff --name-only --diff-filter=ACDMR "$range" 2>/dev/null || true)
  printf '%s' "$blocked"
}

blocked_all=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "${local_sha}" == "0000000000000000000000000000000000000000" ]]; then
    continue
  fi

  if [[ "${remote_sha}" == "0000000000000000000000000000000000000000" ]]; then
    range="${local_sha}"
  else
    range="${remote_sha}..${local_sha}"
  fi

  part="$(collect_blocked "$range")"
  if [[ -n "$part" ]]; then
    blocked_all+="$part"
  fi
done

if [[ -n "$blocked_all" ]]; then
  echo "pre-push 拒绝：以下路径不应推送（map/pgm/apm.params 等）：" >&2
  echo -n "$blocked_all" | sort -u >&2
  exit 1
fi

exit 0
