#!/usr/bin/env bash
# pre-push: 仅允许推送 src/ 下功能包代码；禁止 docs / test / map(pgm) 等上大仓。
# 启用: ./scripts/install-git-hooks.sh

set -euo pipefail

ROOT_ALLOW_RE='^(\.gitignore|\.gitattributes|README\.md|\.githooks/|scripts/install-git-hooks\.sh|scripts/git-untrack-non-src\.sh)$'

is_allowed_path() {
  local f="$1"

  if [[ "$f" =~ $ROOT_ALLOW_RE ]]; then
    return 0
  fi

  if [[ "$f" != src/* ]]; then
    return 1
  fi

  # src 内：文档、地图资源、测试目录
  if [[ "$f" =~ (^|/)docs/ ]]; then
    return 1
  fi
  if [[ "$f" =~ (^|/)test/ ]]; then
    return 1
  fi
  if [[ "$f" =~ (^|/)map/ ]]; then
    return 1
  fi
  if [[ "$f" =~ \.pgm$ ]]; then
    return 1
  fi

  return 0
}

collect_blocked() {
  local range="$1"
  local blocked=""
  local f
  while IFS= read -r f; do
    [[ -z "$f" ]] && continue
    if ! is_allowed_path "$f"; then
      blocked+="${f}"$'\n'
    fi
  done < <(git diff --name-only --diff-filter=ACDMR "$range" 2>/dev/null || true)
  printf '%s' "$blocked"
}

blocked_all=""
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "${local_sha}" == "0000000000000000000000000000000000000000" ]]; then
    continue
  fi

  if [[ "${remote_sha}" == "0000000000000000000000000000000000000000" ]]; then
    range="${local_sha}"
  else
    range="${remote_sha}..${local_sha}"
  fi

  part="$(collect_blocked "$range")"
  if [[ -n "$part" ]]; then
    blocked_all+="$part"
  fi
done

if [[ -n "$blocked_all" ]]; then
  echo "pre-push 拒绝：远程仅允许 src/ 功能包代码（及 .gitignore / .githooks / scripts/install-git-hooks.sh）。" >&2
  echo "以下路径不应推送（docs / test / map / *.pgm 等）：" >&2
  echo -n "$blocked_all" | sort -u >&2
  echo "" >&2
  echo "本地保留、从 Git 索引移除: ./scripts/git-untrack-non-src.sh" >&2
  echo "规则说明见 scripts/install-git-hooks.sh" >&2
  exit 1
fi

exit 0
